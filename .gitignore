# Persistent undo files (managed by Vim, cleaned automatically after 90 days)
temp_dirs/undodir/*
!temp_dirs/undodir/.gitignore
!temp_dirs/undodir/README.md

# OS
.DS_Store

# Erlang/Elixir crash dumps
erl_crash.dump
**/erl_crash.dump

# Tags
tags

# Database queries (may contain connection strings with passwords)
db_queries/

# copilot-chat.vim runtime data (OAuth device + chat tokens)
copilot-chat/

# Test isolation
test/xdg/
test/node/node_modules/
