" ─────────────────────────────────────────────────────────────────────────────
" IT-056 a IT-058: Ausência de conflitos históricos
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-056 leader-tn NAO mapeia para tabnew):
  let m = maparg(',tn', 'n')
  Assert m !~# 'tabnew', ',tn ainda mapeia para tabnew (conflito historico): ' . m

Execute (IT-057 C-t NAO mapeia para tabe):
  let m = maparg('<C-t>', 'n')
  Assert m !~# '\<tabe\>', '<C-t> ainda mapeia para tabe (conflito historico): ' . m

Execute (IT-058 leader-f mapeia para coc-format e nao MRU):
  let m = maparg(',f', 'n')
  Assert m =~# 'coc-format\|coc#\|format', ',f nao mapeia para CoC format: ' . m
  Assert m !~# 'MRU', ',f ainda mapeia para MRU (conflito historico): ' . m

" ─────────────────────────────────────────────────────────────────────────────
" IT-084: Nenhum mapeamento normal de 1 tecla duplicado (conflito exaustivo)
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-084 nenhuma tecla de 1 char tem mapeamentos duplicados em normal):
  let keys_to_check = ['K', 'g', 'z', '[', ']', 'g']
  " Verifica que maparg retorna algo consistente (nao testamos duplicatas
  " de Plug pois sao resolvidos internamente — verificamos ausencia de erro)
  for k in keys_to_check
    let m = maparg(k, 'n', 0, 1)
    " Se tem mapeamento, nao deve estar vazio e deve ter campo 'lhs'
    if !empty(m)
      Assert has_key(m, 'lhs'), 'maparg(' . k . ') retornou dict sem lhs'
    endif
  endfor
  " Verifica especificamente que C-f e C-b sao unicos (nao colidem)
  let cf = maparg('<C-f>', 'n', 0, 1)
  let cb = maparg('<C-b>', 'n', 0, 1)
  Assert !empty(cf), '<C-f> nao tem mapeamento em normal mode'
  Assert !empty(cb), '<C-b> nao tem mapeamento em normal mode'

" ─────────────────────────────────────────────────────────────────────────────
" IT-089 a IT-090: C-f e C-b em normal mode NAO mapeiam para CoC float
" (os mapeamentos CoC float sao apenas em insert mode)
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-089 C-f normal mode resolve para Files e nao coc float):
  let m = maparg('<C-f>', 'n')
  Assert m =~# 'Files', '<C-f> nao resolve para Files em normal mode: ' . m
  Assert m !~# 'coc#float', '<C-f> resolve para coc#float em normal mode — conflito!'

Execute (IT-090 C-b normal mode resolve para Buffers e nao coc float):
  let m = maparg('<C-b>', 'n')
  Assert m =~# 'Buffers', '<C-b> nao resolve para Buffers em normal mode: ' . m
  Assert m !~# 'coc#float', '<C-b> resolve para coc#float em normal mode — conflito!'

" ─────────────────────────────────────────────────────────────────────────────
" IT-091 a IT-103: Refactor — conflitos e mapeamentos mortos removidos
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-091 gv em visual mode NAO sombra o nativo):
  " editor.vim tinha vnoremap gv → VisualSelection/Ack que sombrava gv nativo
  let m = maparg('gv', 'v')
  Assert m !~# 'Ack\|VisualSelection',
        \ 'gv visual sombra o gv nativo (reselect): ' . m

Execute (IT-092 C-p em normal NAO mapeia para yankstack):
  " YankStack removido — C-p fica livre para auto-pairs toggle
  let m = maparg('<C-p>', 'n')
  Assert m !~# 'yankstack', 'C-p ainda mapeia para yankstack: ' . m

Execute (IT-093 C-n em normal NAO mapeia para yankstack):
  let m = maparg('<C-n>', 'n')
  Assert m !~# 'yankstack', 'C-n ainda mapeia para yankstack: ' . m

Execute (IT-094 space NAO tem mapeamento direto em normal):
  " map <space> / removido — <space> livre como prefixo para CocList
  let m = maparg('<space>', 'n')
  Assert empty(m), '<space> tem mapeamento direto (deveria estar livre): ' . m

Execute (IT-095 c-space NAO mapeia para busca reversa em normal):
  " map <c-space> ? removido
  let m = maparg('<c-space>', 'n')
  Assert empty(m) || m !~# '?',
        \ 'c-space mapeia para ? em normal mode: ' . m

