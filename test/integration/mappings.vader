" IT-030 a IT-058, IT-084, IT-089, IT-090: Mapeamentos de teclas

" Helper: verifica que maparg(key, 'n') contém pattern
" Usado em todos os testes de mapeamento abaixo.

" ─────────────────────────────────────────────────────────────────────────────
" IT-030 a IT-055: Mapeamentos definidos
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-030 C-f mapeado para Files):
  let m = maparg('<C-f>', 'n')
  Assert m =~# 'Files', '<C-f> nao mapeia para Files: ' . m

Execute (IT-031 C-b mapeado para Buffers):
  let m = maparg('<C-b>', 'n')
  Assert m =~# 'Buffers', '<C-b> nao mapeia para Buffers: ' . m

Execute (IT-032 C-t mapeado para C-o jump back):
  let m = maparg('<C-t>', 'n')
  " Vim normaliza <C-o> para <C-O> internamente — comparacao case-insensitive
  Assert m =~? '<C-o>', '<C-t> nao mapeia para <C-o>: ' . m

Execute (IT-033 C-] mapeado para coc-definition):
  let m = maparg('<C-]>', 'n')
