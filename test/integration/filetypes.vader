Execute (IT-069 arquivo .jinja detectado como htmljinja):
  new
  silent! file /tmp/test_it069.jinja
  filetype detect
  " Vim detecta .jinja como jinja (alias de htmljinja) dependendo da versao
  Assert &filetype =~# '\(htmljinja\|jinja\)', 'filetype inesperado para .jinja: ' . &filetype
After:
  bdelete!

Execute (IT-070 arquivo .twig detectado como html):
  new
  silent! file /tmp/test_it070.twig
  filetype detect
  " .twig pode ser 'html' ou 'htmldjango' dependendo dos plugins instalados
  Assert &filetype =~# '\(html\|twig\)', 'filetype inesperado para .twig: ' . &filetype
After:
  bdelete!

Execute (IT-071 arquivo .py detectado como python):
  new
  silent! file /tmp/test_it071.py
  filetype detect
  AssertEqual 'python', &filetype
After:
  bdelete!

" ─────────────────────────────────────────────────────────────────────────────
" IT-079 a IT-081: Indentação por filetype
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-079 arquivo .ex tem shiftwidth 2 e expandtab):
  new
  silent! file /tmp/test_it079.ex
  filetype detect
  AssertEqual 2, &shiftwidth
  AssertEqual 1, &expandtab
After:
  bdelete!

Execute (IT-080 arquivo .rb tem shiftwidth 2 e expandtab):
  new
  silent! file /tmp/test_it080.rb
  filetype detect
  AssertEqual 2, &shiftwidth
  AssertEqual 1, &expandtab
After:
  bdelete!

Execute (IT-081 arquivo .heex tem shiftwidth 2 e expandtab):
  new
  silent! file /tmp/test_it081.heex
