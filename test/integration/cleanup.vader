" IT-110 a IT-115: Plugins removidos, adicionados e mantidos
"
" Estes testes garantem que o refactor de limpeza:
" - removeu os 17 plugins mortos do runtimepath
" - adicionou vim-visual-multi como substituto do vim-multiple-cursors
" - manteve vim-go e rust.vim (linguagens desejadas)
" - colorscheme ativo é gruvbox (não desert/peaksea dos layers anteriores)

" ─────────────────────────────────────────────────────────────────────────────
" IT-110: Plugins removidos não estão no runtimepath
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-110 plugins removidos nao estao no runtimepath):
  let removed = [
        \ 'ctrlp.vim', 'comfortable-motion.vim', 'ack.vim',
        \ 'vim-coffee-script', 'vim-bundle-mako', 'vim-pug', 'vim-less',
        \ 'vim-pyte', 'vim-colors-solarized', 'vim-codeclimate',
        \ 'vim-zenroom2', 'open_file_under_cursor.vim', 'bufexplorer',
        \ 'mru.vim', 'nginx.vim', 'vim-multiple-cursors', 'vim-yankstack']
  for plugin in removed
    Assert &rtp !~# 'plugins/' . escape(plugin, '.'),
          \ 'plugin removido ainda no rtp: ' . plugin
  endfor

" ─────────────────────────────────────────────────────────────────────────────
" IT-111: Comandos de plugins removidos não existem
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-111 comandos de plugins removidos nao existem):
  " exists(':Cmd') retorna 2 se existe, 0 se nao
  Assert exists(':CtrlP') == 0, 'comando :CtrlP ainda existe'
  Assert exists(':Ack') == 0, 'comando :Ack ainda existe'
  Assert exists(':BufExplorer') == 0, 'comando :BufExplorer ainda existe'
  Assert exists(':MRU') == 0, 'comando :MRU ainda existe'

" ─────────────────────────────────────────────────────────────────────────────
" IT-112: vim-visual-multi presente (substituto de vim-multiple-cursors)
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-112 vim-visual-multi presente no runtimepath):
  Assert &rtp =~# 'vim-visual-multi',
        \ 'vim-visual-multi nao encontrado no rtp'

" ─────────────────────────────────────────────────────────────────────────────
" IT-113 a IT-114: Plugins mantidos — Go e Rust
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-113 vim-go mantido no runtimepath):
  Assert &rtp =~# 'vim-go',
        \ 'vim-go deveria permanecer no rtp'

Execute (IT-114 rust.vim mantido no runtimepath):
  Assert &rtp =~# 'rust\.vim',
        \ 'rust.vim deveria permanecer no rtp'

" ─────────────────────────────────────────────────────────────────────────────
" IT-115: Colorscheme ativo
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-115 colorscheme ativo e gruvbox):
  " options.vim → desert, editor.vim → peaksea, configs.vim → gruvbox
  " Após limpar os layers anteriores, gruvbox deve ser o ativo
  AssertEqual 'gruvbox', get(g:, 'colors_name', ''),
        \ 'colorscheme ativo nao e gruvbox: ' . get(g:, 'colors_name', 'NONE')

" ─────────────────────────────────────────────────────────────────────────────
" IT-116 a IT-118: Novos plugins — vim-matchup, vim-sleuth
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-116 vim-matchup presente no runtimepath):
  " Matching inteligente de do/end, def/end, tags JSX com %
  Assert &rtp =~# 'vim-matchup',
        \ 'vim-matchup nao encontrado no rtp'

Execute (IT-117 vim-matchup substituiu matchit):
  " vim-matchup define o comando :MatchupWhereAmI
  " e desabilita matchit automaticamente
  Assert exists('g:loaded_matchit') || exists('g:loaded_matchup'),
        \ 'nem matchit nem matchup carregados'

Execute (IT-118 vim-sleuth presente no runtimepath):
  " Deteccao automatica de indent (tabs vs spaces, width)
  Assert &rtp =~# 'vim-sleuth',
        \ 'vim-sleuth nao encontrado no rtp'

" ─────────────────────────────────────────────────────────────────────────────
" IT-152 a IT-155: AI tools — copilot-chat, vim-claude-code, auto-reload
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-152 copilot-chat.vim presente no runtimepath):
  Assert &rtp =~# 'copilot-chat',
        \ 'copilot-chat.vim nao encontrado no rtp'

Execute (IT-153 vim-claude-code presente no runtimepath):
  Assert &rtp =~# 'vim-claude-code',
        \ 'vim-claude-code nao encontrado no rtp'

Execute (IT-154 comando Claude existe):
  Assert exists(':Claude') == 2,
        \ 'comando :Claude nao existe (vim-claude-code nao carregou)'

Execute (IT-155 comando CopilotChatOpen existe):
  Assert exists(':CopilotChatOpen') == 2,
        \ 'comando :CopilotChatOpen nao existe (copilot-chat nao carregou)'

" ─────────────────────────────────────────────────────────────────────────────
" IT-156 a IT-158: vim-tmux-navigator — navegação integrada Vim↔tmux
" ─────────────────────────────────────────────────────────────────────────────

Execute (IT-156 vim-tmux-navigator presente no runtimepath):
  Assert &rtp =~# 'vim-tmux-navigator',
        \ 'vim-tmux-navigator nao encontrado no rtp'

Execute (IT-157 comando TmuxNavigateLeft existe):
  Assert exists(':TmuxNavigateLeft') == 2,
        \ 'comando :TmuxNavigateLeft nao existe (vim-tmux-navigator nao carregou)'

Execute (IT-158 mappings C-h/j/k/l apontam para TmuxNavigate):
  Assert maparg('<c-h>', 'n') =~? 'TmuxNavigateLeft',  'C-h: ' . maparg('<c-h>', 'n')
  Assert maparg('<c-j>', 'n') =~? 'TmuxNavigateDown',  'C-j: ' . maparg('<c-j>', 'n')
  Assert maparg('<c-k>', 'n') =~? 'TmuxNavigateUp',    'C-k: ' . maparg('<c-k>', 'n')
  Assert maparg('<c-l>', 'n') =~? 'TmuxNavigateRight', 'C-l: ' . maparg('<c-l>', 'n')
